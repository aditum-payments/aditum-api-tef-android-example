<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="br.com.aditum.tefexample">

    <supports-screens
        android:largeScreens="true"
        android:smallScreens="true" />
    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_aditum_launcher"
        android:label="@string/launcher_app_name"
        android:roundIcon="@mipmap/ic_aditum_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TefExample.NoActionBar"
        tools:replace="android:allowBackup,android:label">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>