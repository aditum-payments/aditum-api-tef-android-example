<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tbAditum"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_marginTop="10dp">

    <RelativeLayout
        android:id="@+id/llActionBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="30dp"
        android:layout_gravity="center">

        <RelativeLayout
            android:id="@+id/rlActionBarText"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:layout_centerVertical="true"
            android:layout_marginStart="50dp"
            android:background="@drawable/ic_gradient_round_background">

            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:ellipsize="end"
                android:fontFamily="sans-serif-thin"
                android:gravity="center"
                android:maxLength="30"
                android:maxLines="1"
                android:shadowColor="@color/black"
                android:text="@string/app_short_name"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <ProgressBar
                android:id="@+id/pbLoading"
                style="?android:attr/progressBarStyle"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="5dp"
                android:backgroundTint="@color/white" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/llActionBarImg"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:layout_centerVertical="true"
            android:background="@drawable/ic_gradient_round_background"
            android:backgroundTint="@color/light_gray"
            android:backgroundTintMode="src_in"
            android:paddingVertical="3dp">

            <ImageView
                android:id="@+id/ivCustomerIco"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/a_ditum_color_nobg_sh"
                android:layout_marginHorizontal="13dp"
                android:layout_marginVertical="3dp" />
        </LinearLayout>

    </RelativeLayout>

</androidx.appcompat.widget.Toolbar>